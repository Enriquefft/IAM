---
import "@/styles/globals.css";
import Nav from "@/components/nav/Nav.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Skip link — first focusable in <body>, targets #main. Landing Page.html:54 -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded-base focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-fg focus:ring-2 focus:ring-primary focus:outline-none"
    >
      Saltar al contenido principal
    </a>

    <Nav />

    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
