---
import "@/styles/globals.css";
import Nav from "@/components/nav/Nav.astro";
import { siteMeta, DEFAULT_LOCALE, localeToOgLocale } from "@/lib/seo";
import type { PageMeta } from "@/lib/seo";

interface Props {
  /** Legacy title-only shorthand — prefer pageMeta for full SEO control */
  title?: string;
  pageMeta?: PageMeta;
  /** Absolute canonical URL override — if omitted, derived from Astro.url */
  canonicalUrl?: string;
}

const { title, pageMeta, canonicalUrl: canonicalOverride } = Astro.props;

// Resolve effective metadata: pageMeta takes priority; title-only is the fallback
const effectiveTitle = pageMeta?.title ?? title ?? siteMeta.siteName;
const effectiveDescription = pageMeta?.description;
const effectiveNoindex = pageMeta?.noindex ?? false;
const effectiveOgType = pageMeta?.ogType ?? "website";
const canonical =
  canonicalOverride ??
  (pageMeta?.canonicalPath
    ? `${siteMeta.siteUrl}${pageMeta.canonicalPath}`
    : Astro.url.href.replace(/\/$/, "") || siteMeta.siteUrl);

const ogImage = siteMeta.defaultOgImage;
// i18n seam: today uses DEFAULT_LOCALE. The i18n agent will derive this from routing.
const activeLocale = DEFAULT_LOCALE;
const ogLocale = localeToOgLocale(activeLocale);
// html lang uses BCP 47 subtag (es-PE → es). The i18n agent will make this locale-aware.
const htmlLang = activeLocale.split("-")[0] ?? "es";

// ---------------------------------------------------------------------------
// JSON-LD structured data
// ---------------------------------------------------------------------------
const isRoot = new URL(Astro.url.href).pathname === "/";
const pathSegments = new URL(Astro.url.href).pathname
  .split("/")
  .filter(Boolean);

const organizationLd = {
  "@type": "Organization",
  name: "i-am.clinic",
  url: siteMeta.siteUrl,
  email: siteMeta.email,
  address: {
    "@type": "PostalAddress",
    addressLocality: siteMeta.address.locality,
    addressCountry: siteMeta.address.country,
  },
};

const websiteLd = {
  "@type": "WebSite",
  url: siteMeta.siteUrl,
  name: siteMeta.siteName,
  // i18n seam: the i18n agent will make this locale-aware per-page
  inLanguage: activeLocale,
};

const softwareAppLd = {
  "@type": "SoftwareApplication",
  name: "i-am.clinic",
  applicationCategory: "HealthApplication",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    priceCurrency: "USD",
  },
};

// BreadcrumbList for non-root pages
const breadcrumbLd =
  !isRoot && pathSegments.length > 0
    ? {
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Inicio",
            item: siteMeta.siteUrl,
          },
          {
            "@type": "ListItem",
            position: 2,
            name: effectiveTitle.split(" — ")[0] ?? effectiveTitle,
            item: canonical,
          },
        ],
      }
    : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organizationLd,
    websiteLd,
    softwareAppLd,
    ...(breadcrumbLd ? [breadcrumbLd] : []),
  ],
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary meta -->
    <title>{effectiveTitle}</title>
    {effectiveDescription && <meta name="description" content={effectiveDescription} />}
    {effectiveNoindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow" />
    }
    <link rel="canonical" href={canonical} />

    <!-- Theme color: brand.cream.50 — SSOT exception documented in CLAUDE.md -->
    <meta name="theme-color" content={siteMeta.themeColor} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteMeta.siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:type" content={effectiveOgType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={effectiveTitle} />
    {effectiveDescription && <meta property="og:description" content={effectiveDescription} />}
    <meta property="og:image" content={ogImage} />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content={siteMeta.twitterCard} />
    <meta name="twitter:title" content={effectiveTitle} />
    {effectiveDescription && <meta name="twitter:description" content={effectiveDescription} />}
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts: @fontsource — self-hosted, no preconnect needed -->

    <!-- JSON-LD structured data — is:inline required: set:html attribute disables Astro script processing, which is correct here -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <!-- Skip link — first focusable in <body>, targets #main. Landing Page.html:54 -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded-base focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-fg focus:ring-2 focus:ring-primary focus:outline-none"
    >
      Saltar al contenido principal
    </a>

    <Nav />

    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
