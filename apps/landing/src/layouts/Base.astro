---
import "@/styles/globals.css";
import Nav from "@/components/nav/Nav.astro";
import {
  siteMeta,
  siteAddress,
  buildPageMeta,
  type PageMeta,
  type PageKey,
} from "@/lib/seo";
import {
  COUNTRIES,
  PRICING_BY_LOCALE,
  SUPPORTED_LOCALES,
  DEFAULT_LOCALE_PATH,
  PATH_TO_LOCALE,
  parseLocaleFromPath,
  pathToLocale,
  localeToPath,
  localeToOgLocale,
  localizePath,
  type Locale,
  type LocalePath,
} from "@/lib/i18n";

interface Props {
  /**
   * Page-key + locale shortcut: composes the PageMeta via {@link buildPageMeta}.
   * Preferred form for routed pages. If you pass `pageMeta` directly, it wins.
   */
  pageKey?: PageKey;
  /** Locale of the current page (path segment, e.g. "pe"). */
  locale?: LocalePath;
  /** Pre-composed PageMeta — use when `pageKey` doesn't fit (e.g., kitchen-sink). */
  pageMeta?: PageMeta;
  /** Title-only shorthand for dev/utility pages. */
  title?: string;
  /** Absolute canonical URL override; if omitted, derived from Astro.url. */
  canonicalUrl?: string;
}

const {
  pageKey,
  locale: localeProp,
  pageMeta: pageMetaProp,
  title,
  canonicalUrl: canonicalOverride,
} = Astro.props;

// Locale derivation order:
// 1. Explicit `locale` prop from the page (always set on routed pages).
// 2. Parsed from URL pathname (covers /og.png, 404s, dev preview).
// 3. Default locale (utility/static surfaces).
const localePathFromUrl = ((): LocalePath | null => {
  const parsed = parseLocaleFromPath(Astro.url.pathname);
  return parsed === null ? null : localeToPath(parsed);
})();
const activeLocalePath: LocalePath =
  localeProp ?? localePathFromUrl ?? DEFAULT_LOCALE_PATH;
const activeLocale: Locale = pathToLocale(activeLocalePath);

// PageMeta resolution: prop > pageKey factory > title-only fallback.
const resolvedPageMeta: PageMeta | undefined =
  pageMetaProp ?? (pageKey !== undefined ? buildPageMeta(pageKey, activeLocale) : undefined);

const effectiveTitle = resolvedPageMeta?.title ?? title ?? siteMeta.siteName;
const effectiveDescription = resolvedPageMeta?.description;
const effectiveNoindex = resolvedPageMeta?.noindex ?? false;
const effectiveOgType = resolvedPageMeta?.ogType ?? "website";

// Canonical: prefer override → pageMeta.canonicalPath → current pathname.
// Strip trailing slash for consistency (Astro renders /pe and /pe/demo without trailing).
const pathname = Astro.url.pathname.replace(/\/$/, "") || `/${activeLocalePath}`;
const canonical =
  canonicalOverride ??
  (resolvedPageMeta?.canonicalPath
    ? `${siteMeta.siteUrl}${resolvedPageMeta.canonicalPath}`
    : `${siteMeta.siteUrl}${pathname}`);

// Subpath under the locale prefix — used to compose hreflang alternates.
// "/pe/demo" → "/demo", "/pe" → "" (root of that locale).
const localePrefix = `/${activeLocalePath}`;
const subpathBeyondLocale = pathname.startsWith(localePrefix)
  ? pathname.slice(localePrefix.length)
  : "";

// hreflang alternates: one per locale + x-default → DEFAULT_LOCALE.
const hreflangAlternates = SUPPORTED_LOCALES.map((loc) => {
  const path = localeToPath(loc);
  return {
    hreflang: loc, // BCP 47 (es-PE, es-MX, …)
    href: `${siteMeta.siteUrl}${localizePath(path, subpathBeyondLocale)}`,
  };
});
const xDefaultHref = `${siteMeta.siteUrl}${localizePath(DEFAULT_LOCALE_PATH, subpathBeyondLocale)}`;

// OG locale + alternates
const ogLocale = localeToOgLocale(activeLocale);
const ogLocaleAlternates = SUPPORTED_LOCALES
  .filter((loc) => loc !== activeLocale)
  .map((loc) => localeToOgLocale(loc));

// OG image — append locale so the image varies per country.
const ogImage = `${siteMeta.siteUrl}/og.png?locale=${activeLocalePath}`;

// HTML lang — use full BCP 47 (es-PE, es-MX, …) for richer signals.
const htmlLang = activeLocale;

// JSON-LD: organization, website, software-app — locale-aware
const country = COUNTRIES[activeLocale];
const address = siteAddress(activeLocale);
const tierPricing = PRICING_BY_LOCALE[activeLocale].consultorio;

const isLocaleRoot = pathname === localePrefix;
const pathSegmentsBeyondLocale = subpathBeyondLocale
  .split("/")
  .filter(Boolean);

const organizationLd = {
  "@type": "Organization",
  name: "i-am.clinic",
  url: siteMeta.siteUrl,
  email: siteMeta.email,
  address: {
    "@type": "PostalAddress",
    addressLocality: address.locality,
    addressCountry: address.country,
  },
};

const websiteLd = {
  "@type": "WebSite",
  url: `${siteMeta.siteUrl}${localePrefix}`,
  name: siteMeta.siteName,
  inLanguage: activeLocale,
};

const softwareAppLd = {
  "@type": "SoftwareApplication",
  name: "i-am.clinic",
  applicationCategory: "HealthApplication",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: tierPricing.amount,
    priceCurrency: country.currency.code,
  },
};

const breadcrumbLd =
  !isLocaleRoot && pathSegmentsBeyondLocale.length > 0
    ? {
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Inicio",
            item: `${siteMeta.siteUrl}${localePrefix}`,
          },
          {
            "@type": "ListItem",
            position: 2,
            name: effectiveTitle.split(" — ")[0] ?? effectiveTitle,
            item: canonical,
          },
        ],
      }
    : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    organizationLd,
    websiteLd,
    softwareAppLd,
    ...(breadcrumbLd ? [breadcrumbLd] : []),
  ],
};

// Sanity: validate localeProp against PATH_TO_LOCALE if provided. Fail loud in
// dev; in prod the page route should never call us with a bad path.
if (localeProp !== undefined && PATH_TO_LOCALE[localeProp] === undefined) {
  throw new Error(`Base.astro: unsupported locale prop "${localeProp}"`);
}
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary meta -->
    <title>{effectiveTitle}</title>
    {effectiveDescription && <meta name="description" content={effectiveDescription} />}
    {effectiveNoindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow" />
    }
    <link rel="canonical" href={canonical} />

    <!-- hreflang alternates: one per supported locale + x-default → /pe -->
    {hreflangAlternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <!-- Theme color: brand.cream.50 — SSOT exception documented in CLAUDE.md -->
    <meta name="theme-color" content={siteMeta.themeColor} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteMeta.siteName} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((loc) => (
      <meta property="og:locale:alternate" content={loc} />
    ))}
    <meta property="og:type" content={effectiveOgType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={effectiveTitle} />
    {effectiveDescription && <meta property="og:description" content={effectiveDescription} />}
    <meta property="og:image" content={ogImage} />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content={siteMeta.twitterCard} />
    <meta name="twitter:title" content={effectiveTitle} />
    {effectiveDescription && <meta name="twitter:description" content={effectiveDescription} />}
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- JSON-LD structured data — is:inline required: set:html attribute disables Astro script processing, which is correct here -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <!-- Skip link — first focusable in <body>, targets #main. -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded-base focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-fg focus:ring-2 focus:ring-primary focus:outline-none"
    >
      Saltar al contenido principal
    </a>

    <Nav locale={activeLocalePath} />

    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
