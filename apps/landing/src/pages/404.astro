---
// 404.astro — rendered for any path that doesn't match a route AND isn't
// caught by middleware redirect. Locale is derived from URL when possible
// (e.g. /pe/foo) else falls back to the iam:locale cookie or default.
import Base from "@/layouts/Base.astro";
import Footer from "@/components/sections/Footer.astro";
import {
  parseLocaleFromPath,
  localeToPath,
  isLocalePath,
  DEFAULT_LOCALE_PATH,
  localeRoot,
  localeAnchor,
  type LocalePath,
} from "@/lib/i18n";

function pickLocale(): LocalePath {
  const fromPath = parseLocaleFromPath(Astro.url.pathname);
  if (fromPath !== null) return localeToPath(fromPath);
  const cookie = Astro.cookies.get("iam:locale")?.value;
  if (typeof cookie === "string" && isLocalePath(cookie)) return cookie;
  return DEFAULT_LOCALE_PATH;
}

const locale = pickLocale();
const homeUrl = localeRoot(locale);
const waitlistUrl = localeAnchor(locale, "waitlist");
---

<Base pageKey="notFound" locale={locale}>
  <div class="min-h-[80vh] flex items-center justify-center px-8 py-24 bg-page">
    <div class="mx-auto max-w-[480px] text-center">

      <!-- Decorative mark -->
      <div
        class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-brand-cream-100 border border-surface-border mb-8"
        aria-hidden="true"
      >
        <span class="font-serif text-3xl font-bold text-brand-salvia-600 select-none">
          404
        </span>
      </div>

      <h1 class="font-sans text-h2 font-bold text-text-primary mb-4">
        Página no encontrada
      </h1>

      <p class="font-serif text-body-lg text-text-secondary mb-10 leading-relaxed">
        El enlace que seguiste no existe o fue movido.<br />
        Puedes volver al inicio o unirte a la lista de espera.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href={homeUrl}
          class="inline-flex items-center gap-2 rounded-base h-11 px-6 text-small font-semibold bg-primary text-primary-fg hover:bg-primary-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-page transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path d="M6 13L11 8 6 3" />
          </svg>
          Volver al inicio
        </a>

        <a
          href={waitlistUrl}
          class="inline-flex items-center gap-2 rounded-base h-11 px-6 text-small font-semibold bg-surface text-text-primary border border-surface-border hover:bg-surface-alt focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-page transition-colors"
        >
          Unirme a la lista de espera
        </a>
      </div>

    </div>
  </div>

  <Footer slot="footer" locale={locale} />
</Base>
