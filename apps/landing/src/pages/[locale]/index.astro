---
import Base from "@/layouts/Base.astro";
import Hero from "@/components/sections/Hero.astro";
import Backers from "@/components/sections/Backers.astro";
import Features from "@/components/sections/Features.astro";
import Pricing from "@/components/sections/Pricing.astro";
import Equipo from "@/components/sections/Equipo.astro";
import Faq from "@/components/sections/Faq.astro";
import FinalCta from "@/components/sections/FinalCta.astro";
import Waitlist from "@/components/sections/Waitlist.astro";
import Footer from "@/components/sections/Footer.astro";
import { isLocalePath, type LocalePath } from "@/lib/i18n";

const param = Astro.params.locale;
if (!isLocalePath(param)) return Astro.redirect("/", 302);
const locale: LocalePath = param;
---

<Base pageKey="home" locale={locale}>
  <Hero locale={locale} />
  <Backers />
  <Features locale={locale} />
  <Pricing locale={locale} />
  <Equipo locale={locale} />
  <Faq locale={locale} />
  <FinalCta locale={locale} />
  <Waitlist locale={locale} />
  <Footer slot="footer" locale={locale} />
</Base>
