---
import Base from "@/layouts/Base.astro";
import HomePage from "@/components/pages/HomePage.astro";
import Footer from "@/components/sections/Footer.astro";
import { DEFAULT_LOCALE_PATH } from "@/lib/i18n";
import { siteMeta } from "@/lib/seo";

const locale = DEFAULT_LOCALE_PATH;
const canonicalUrl = `${siteMeta.siteUrl}/`;
---

<Base pageKey="home" locale={locale} canonicalUrl={canonicalUrl}>
  <HomePage locale={locale} />
  <Footer slot="footer" locale={locale} />
</Base>
