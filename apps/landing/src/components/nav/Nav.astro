---
// Nav.astro — server-rendered sticky header shell.
// Embeds NavLinks (desktop, zero JS) and NavMobile (React island, client:idle).
// Locale-aware: every link, including the logo home link, derives from `locale`.
import Logo from "@/components/brand/Logo.astro";
import { Button } from "@/components/ui/button";
import NavLinks from "./NavLinks.astro";
import NavMobile from "./NavMobile";
import LocaleSwitcher from "./LocaleSwitcher";
import {
  buildNavLinks,
  WAITLIST_CTA,
  demoHref,
  waitlistHref,
} from "./links";
import { localeRoot, type LocalePath } from "@/lib/i18n";

interface Props {
  readonly locale: LocalePath;
}
const { locale }: Props = Astro.props;

const homeUrl = localeRoot(locale);
const links = buildNavLinks(locale);
const demoUrl = demoHref(locale);
const waitlistUrl = waitlistHref(locale);
---

<!-- Sticky header shell — data-nav-shell is the scroll-shadow anchor read by NavMobile.tsx -->
<header
  data-nav-shell
  data-scrolled="false"
  class="sticky top-0 z-50 bg-page/85 backdrop-blur supports-[backdrop-filter]:bg-page/75 border-b border-transparent transition-colors duration-200 ease-out data-[scrolled=true]:border-surface-border motion-reduce:transition-none"
>
  <div class="mx-auto flex max-w-page items-center justify-between gap-6 px-8 py-3.5 sm:px-5">

    <!-- Logo link — locale-prefixed home -->
    <a
      href={homeUrl}
      aria-label="i-am.clinic — inicio"
      class="inline-flex items-center gap-2.5 rounded-base focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-page"
    >
      <Logo class="h-8" />
    </a>

    <!-- Desktop link list (zero JS) -->
    <NavLinks variant="desktop" locale={locale} />

    <!-- Desktop CTA + locale switcher -->
    <div class="hidden md:flex items-center gap-3">
      <LocaleSwitcher client:idle currentPath={locale} />
      <Button asChild>
        <a href={waitlistUrl}>{WAITLIST_CTA}</a>
      </Button>
    </div>

    <!-- Mobile island: scroll-shadow watcher + Sheet drawer -->
    <NavMobile
      client:idle
      links={links}
      ctaLabel={WAITLIST_CTA}
      ctaHref={waitlistUrl}
      demoHref={demoUrl}
      demoLabel="Ver demo →"
      currentPath={locale}
    />

  </div>
</header>
