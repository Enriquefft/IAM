---
// NavLinks.astro — desktop navigation link list (zero JS, SSR only).
// section-nav.jsx:42 aria-label, section-nav.jsx:21-25 link text.
import { NAV_LINKS } from "./links";

interface Props {
  variant: "desktop";
}

// variant is declared for future extensibility; consumed by type-check.
const { variant: _variant }: Props = Astro.props;
---

<!-- section-nav.jsx:42 aria-label="Navegación principal" -->
<nav
  aria-label="Navegación principal"
  class="hidden md:flex items-center gap-7"
>
  {NAV_LINKS.map(({ href, label }) => (
    <a
      href={href}
      class="text-label text-ink-700 hover:text-ink-900 transition-colors rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-page"
    >
      {label}
    </a>
  ))}
</nav>
