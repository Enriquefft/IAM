---
// Wordmark.astro — text-only wordmark portion of the logo.
// Derived from the text element in assets/logo.svg.
// viewBox sized to contain only the text (192×32, x-offset removed).
import { cn } from "@/lib/cn";

interface Props {
  class?: string;
  "aria-label"?: string;
}

const {
  class: className,
  "aria-label": ariaLabel = "i-am.clinic",
}: Props = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 192 32"
  role="img"
  aria-label={ariaLabel}
  fill="currentColor"
  class={cn(className)}
>
  <text
    x="0"
    y="24"
    font-family="Plus Jakarta Sans, system-ui, sans-serif"
    font-weight="700"
    font-size="22"
    letter-spacing="-0.01em"
    class="text-text-primary"
    fill="currentColor"
  >i-am<tspan class="text-primary" fill="currentColor">.</tspan>clinic</text>
</svg>
