---
// Small.astro — small text.
import { cn } from "@/lib/cn";

type AllowedTag = "h1" | "h2" | "h3" | "h4" | "p" | "span" | "div";

interface Props {
  as?: AllowedTag;
  class?: string;
}

const { as: Tag = "p", class: className }: Props = Astro.props;
---

<Tag
  class={cn("font-sans text-small text-text-muted", className)}
>
  <slot />
</Tag>
