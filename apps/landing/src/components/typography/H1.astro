---
// H1.astro — h1 visual weight, configurable semantic tag via `as` prop.
import { cn } from "@/lib/cn";

type AllowedTag = "h1" | "h2" | "h3" | "h4" | "p" | "span" | "div";

interface Props {
  as?: AllowedTag;
  class?: string;
}

const { as: Tag = "h1", class: className } = Astro.props;
---

<Tag
  class:list={[
    "font-sans text-h1 text-text-primary",
    className,
  ]}
>
  <slot />
</Tag>
