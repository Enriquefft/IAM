---
// Hero.astro — Phase-4.2 static hero frame.
// No props — all copy is hard-coded inline.
import Lede from "@/components/typography/Lede.astro";
import Icon from "@/components/icons/Icon.astro";
import Mark from "@/components/brand/Mark.astro";
import { Button } from "@/components/ui/button";
---

{/* section-hero.jsx:1 */}
<section
  id="hero"
  aria-labelledby="hero-title"
  class="relative overflow-hidden bg-page pt-18 pb-24 lg:pt-[72px] lg:pb-24"
>
  {/* Decorative radial wash — no semantic content */}
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-hero-wash"></div>

  {/* Two-column grid: copy left, preview right */}
  <div class="mx-auto max-w-page px-8 grid items-center gap-16 lg:grid-cols-[1.05fr_0.95fr] grid-cols-1 relative">

    {/* ── LEFT COLUMN: copy ─────────────────────────────────── */}
    <div>
      {/* Eyebrow badge */}
      {/* section-hero.jsx:19 */}
      <span class="inline-flex items-center gap-1.5 rounded-full bg-surface-alt text-text-secondary text-label font-medium px-3 py-1 border border-surface-border">
        {/* section-hero.jsx:19 */}Hecho por gente que también ve pacientes
      </span>

      {/* Main headline */}
      {/* section-hero.jsx:20 */}
      <h1
        id="hero-title"
        class="text-hero-fluid font-sans font-bold tracking-tight leading-tight mt-5 mb-6"
      >
        {/* section-hero.jsx:21 */}La consulta privada,{" "}
        <span class="text-brand-salvia-500 italic font-serif font-medium">{/* section-hero.jsx:22 */}sin papeleo.</span>
      </h1>

      {/* Lede paragraph */}
      {/* section-hero.jsx:26-29 */}
      <Lede class="text-text-secondary max-w-[540px] mb-8">
        {/* section-hero.jsx:27 */}Agenda, notas y cobros en un mismo lugar. Para psicólogos y psiquiatras que quieren cerrar el día con sus pacientes, no con una hoja de cálculo.
      </Lede>

      {/* CTA group */}
      <div class="flex flex-wrap gap-3 mb-5">
        {/* Primary CTA — links to #waitlist (Phase-6 will mount the WaitlistDialog there) */}
        {/* section-hero.jsx:32 */}
        <Button asChild size="lg">
          <a href="#waitlist">
            {/* section-hero.jsx:33 */}Unirme a la lista de espera
            <Icon name="arrowRight" class="ml-1 h-[18px] w-[18px]" aria-hidden="true" />
          </a>
        </Button>

        {/* Secondary CTA */}
        {/* section-hero.jsx:36 */}
        <Button asChild variant="outline" size="lg">
          <a href="/demo">
            {/* section-hero.jsx:37 */}Ver el demo
          </a>
        </Button>
      </div>

      {/* Trust line */}
      {/* section-hero.jsx:40 */}
      <p class="text-small text-text-muted mt-3 inline-flex items-center gap-2">
        <Icon name="lock" class="h-[14px] w-[14px]" aria-hidden="true" />
        {/* section-hero.jsx:42 */}Tus expedientes están cifrados. Solo tú los lees.
      </p>
    </div>

    {/* ── RIGHT COLUMN: preview chrome ──────────────────────── */}
    <div class="relative">
      {/* Tilt-target interactive button — click navigates to /demo with tilt handoff */}
      {/* section-hero.jsx:76 */}
      <button
        data-tilt-target
        type="button"
        aria-label="Abrir el demo interactivo"
        class="group relative block w-full aspect-[1.05/1] rounded-hero overflow-visible bg-transparent border-0 p-0 text-left focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-salvia-400 focus-visible:ring-offset-[6px] focus-visible:ring-offset-page transition-transform duration-300 ease-spring motion-reduce:transition-none [transform-style:preserve-3d] [perspective:1200px]"
      >
        {/* Preview chrome mockup */}
        {/* section-hero.jsx:156 */}
        <div aria-hidden="true" class="bg-surface border border-surface-border rounded-2xl overflow-hidden shadow-md">

          {/* Chrome titlebar */}
          <div class="flex items-center gap-2.5 px-3.5 py-2.5 bg-surface-alt border-b border-surface-border">
            {/* Traffic lights */}
            <span class="size-2.5 rounded-full bg-brand-terra-300"></span>
            <span class="size-2.5 rounded-full bg-brand-wood-300"></span>
            <span class="size-2.5 rounded-full bg-brand-salvia-200"></span>
            {/* URL pill */}
            <div class="flex-1 h-[22px] rounded-md bg-surface border border-surface-border flex items-center gap-1.5 px-2.5 font-sans text-[11px] text-text-muted">
              {/* section-hero.jsx:182 */}app.i-am.clinic / agenda
            </div>
          </div>

          {/* App body: sidebar + main */}
          <div class="grid grid-cols-[180px_1fr] min-h-[360px] bg-surface">

            {/* Sidebar */}
            <nav class="bg-surface-alt border-r border-surface-border px-3.5 py-4.5 flex flex-col gap-1">

              {/* Logo row */}
              <div class="flex items-center gap-2 px-1.5 pb-3.5">
                <Mark class="h-[22px] w-[22px]" aria-hidden="true" />
                <span class="font-sans text-sm font-bold text-text-primary">{/* section-hero.jsx:206 */}i-am.clinic</span>
              </div>

              {/* Sidebar nav items */}
              {/* section-hero.jsx:208 — active item */}
              <div class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg bg-surface text-brand-salvia-600 font-sans text-[13px] font-semibold shadow-sm">
                <Icon name="calendar" class="h-[14px] w-[14px]" aria-hidden="true" />
                {/* section-hero.jsx:208 */}Agenda
              </div>
              {/* section-hero.jsx:209 */}
              <div class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg bg-transparent text-text-secondary font-sans text-[13px] font-medium">
                <Icon name="fileText" class="h-[14px] w-[14px]" aria-hidden="true" />
                {/* section-hero.jsx:209 */}Notas
              </div>
              {/* section-hero.jsx:210 */}
              <div class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg bg-transparent text-text-secondary font-sans text-[13px] font-medium">
                <Icon name="message" class="h-[14px] w-[14px]" aria-hidden="true" />
                {/* section-hero.jsx:210 */}Pacientes
              </div>
              {/* section-hero.jsx:211 */}
              <div class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg bg-transparent text-text-secondary font-sans text-[13px] font-medium">
                <Icon name="check" class="h-[14px] w-[14px]" aria-hidden="true" />
                {/* section-hero.jsx:211 */}Cobros
              </div>

              {/* Profile footer */}
              <div class="mt-auto pt-3.5 border-t border-surface-border flex items-center gap-2">
                <div class="grid place-items-center h-7 w-7 rounded-full bg-brand-terra-100 text-brand-terra-600 font-sans font-semibold text-[11px]">
                  {/* section-hero.jsx:218 */}MR
                </div>
                <div class="font-sans text-[12px] leading-snug">
                  <p class="font-semibold text-text-primary truncate">{/* section-hero.jsx:220 */}Dra. Reséndiz</p>
                  <p class="text-text-muted truncate">{/* section-hero.jsx:221 */}Lima · Miraflores</p>
                </div>
              </div>
            </nav>

            {/* Main content column */}
            <div class="px-5 py-4.5 flex flex-col gap-3.5">

              {/* Header row */}
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-sans text-[11px] text-text-muted tracking-[0.4px] uppercase">{/* section-hero.jsx:230 */}Martes</p>
                  <p class="font-sans text-lg font-bold text-text-primary">{/* section-hero.jsx:231 */}14 de mayo</p>
                </div>
                <span class="bg-brand-salvia-100 text-brand-salvia-600 px-2.5 py-1 rounded-full font-sans text-[11px] font-medium">{/* section-hero.jsx:237 */}5 sesiones · 4 confirmadas</span>
              </div>

              {/* Session list — five rows from bundle :241-245 */}
              <div class="flex flex-col gap-2">

                {/* Row 1: 9:00 · Carlos D. · seguimiento — no confirmed chip, neutral tone */}
                {/* section-hero.jsx:241 */}
                <div class="grid grid-cols-[56px_1fr_auto] items-center gap-3.5 px-3 py-2.5 rounded-[10px] border border-transparent">
                  <div class="text-center">
                    <p class="font-sans text-[13px] font-semibold text-text-primary">9:00</p>
                  </div>
                  <div>
                    <p class="font-sans text-[13px] font-semibold text-text-primary">Carlos D.</p>
                    <span class="bg-surface-border text-text-secondary px-2 py-0.5 rounded-full font-sans text-[11px] font-medium">seguimiento</span>
                  </div>
                  <span></span>
                </div>

                {/* Row 2: 11:00 · Ana Martínez · primera vez — highlight row, salvia tone */}
                {/* section-hero.jsx:242 */}
                <div class="grid grid-cols-[56px_1fr_auto] items-center gap-3.5 px-3 py-2.5 rounded-[10px] bg-surface-alt border border-brand-salvia-200">
                  <div class="text-center">
                    <p class="font-sans text-[13px] font-semibold text-text-primary">11:00</p>
                  </div>
                  <div>
                    <p class="font-sans text-[13px] font-semibold text-text-primary">Ana Martínez</p>
                    <span class="bg-brand-salvia-100 text-brand-salvia-600 px-2 py-0.5 rounded-full font-sans text-[11px] font-medium">primera vez</span>
                  </div>
                  <span></span>
                </div>

                {/* Row 3: 13:30 · Lucía P. · pareja — no confirmed chip, terra/warm tone */}
                {/* section-hero.jsx:243 */}
                <div class="grid grid-cols-[56px_1fr_auto] items-center gap-3.5 px-3 py-2.5 rounded-[10px] border border-transparent">
                  <div class="text-center">
                    <p class="font-sans text-[13px] font-semibold text-text-primary">13:30</p>
                  </div>
                  <div>
                    <p class="font-sans text-[13px] font-semibold text-text-primary">Lucía P.</p>
                    <span class="bg-brand-terra-100 text-brand-terra-600 px-2 py-0.5 rounded-full font-sans text-[11px] font-medium">pareja</span>
                  </div>
                  <span></span>
                </div>

                {/* Row 4: 17:00 · Diego H. · seguimiento — confirmed chip */}
                {/* section-hero.jsx:244 */}
                <div class="grid grid-cols-[56px_1fr_auto] items-center gap-3.5 px-3 py-2.5 rounded-[10px] border border-transparent">
                  <div class="text-center">
                    <p class="font-sans text-[13px] font-semibold text-text-primary">17:00</p>
                  </div>
                  <div>
                    <p class="font-sans text-[13px] font-semibold text-text-primary">Diego H.</p>
                    <span class="bg-surface-border text-text-secondary px-2 py-0.5 rounded-full font-sans text-[11px] font-medium">seguimiento</span>
                  </div>
                  <span class="inline-flex items-center gap-1 font-sans text-[11px] text-brand-salvia-600 font-medium">
                    <Icon name="check" class="h-[12px] w-[12px]" aria-hidden="true" />
                    {/* section-hero.jsx:285 */}confirmada
                  </span>
                </div>

                {/* Row 5: 18:30 · Sofía R. · evaluación — confirmed chip */}
                {/* section-hero.jsx:245 */}
                <div class="grid grid-cols-[56px_1fr_auto] items-center gap-3.5 px-3 py-2.5 rounded-[10px] border border-transparent">
                  <div class="text-center">
                    <p class="font-sans text-[13px] font-semibold text-text-primary">18:30</p>
                  </div>
                  <div>
                    <p class="font-sans text-[13px] font-semibold text-text-primary">Sofía R.</p>
                    <span class="bg-brand-salvia-100 text-brand-salvia-600 px-2 py-0.5 rounded-full font-sans text-[11px] font-medium">evaluación</span>
                  </div>
                  <span class="inline-flex items-center gap-1 font-sans text-[11px] text-brand-salvia-600 font-medium">
                    <Icon name="check" class="h-[12px] w-[12px]" aria-hidden="true" />
                    {/* section-hero.jsx:285 */}confirmada
                  </span>
                </div>

              </div>
            </div>
          </div>
        </div>

        {/* Floating card — top-left */}
        {/* section-hero.jsx:108 */}
        <div class="absolute -top-4 -left-5.5 bg-surface border border-surface-border rounded-xl px-3.5 py-2.5 shadow-md flex items-center gap-3 motion-safe:animate-floatIn">
          <span class="grid place-items-center h-8 w-8 rounded-full bg-brand-salvia-100 text-brand-salvia-600 font-sans font-semibold text-[11px]">
            <Icon name="calendar" class="h-[18px] w-[18px]" aria-hidden="true" />
          </span>
          <div>
            <p class="font-sans text-[12px] font-semibold text-text-primary">{/* section-hero.jsx:117 */}Hoy · 5:00 pm</p>
            <p class="font-sans text-[11px] text-text-muted">{/* section-hero.jsx:118 */}Ana M. · primera sesión</p>
          </div>
        </div>

        {/* Floating card — bottom-right */}
        {/* section-hero.jsx:122 */}
        <div class="absolute bottom-7 -right-5.5 bg-surface border border-surface-border rounded-xl px-3.5 py-2.5 shadow-md flex items-center gap-3 motion-safe:animate-floatIn">
          <span class="grid place-items-center h-8 w-8 rounded-full bg-brand-salvia-100 text-brand-salvia-600 font-sans font-semibold text-[11px]">
            <Icon name="check" class="h-[18px] w-[18px]" aria-hidden="true" />
          </span>
          <div>
            <p class="font-sans text-[12px] font-semibold text-text-primary">{/* section-hero.jsx:131 */}Pago recibido</p>
            <p class="font-sans text-[11px] text-text-muted">{/* section-hero.jsx:132 */}$80 · recibo enviado</p>
          </div>
        </div>

        {/* Mini chip overlay — visible on hover/focus */}
        {/* section-hero.jsx:137 */}
        <span
          aria-hidden="true"
          class="absolute left-1/2 -translate-x-1/2 -bottom-4 inline-flex items-center gap-1.5 rounded-full bg-surface text-text-primary text-micro font-medium px-2.5 py-1 border border-surface-border opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity motion-reduce:transition-none"
        >
          {/* section-hero.jsx:149 */}Abrir demo interactivo
          <Icon name="arrowRight" class="h-[14px] w-[14px]" aria-hidden="true" />
        </span>

      </button>
    </div>

  </div>
</section>

<script type="module" is:inline>
const target = document.querySelector('[data-tilt-target]');
if (target) {
  const writeHandoff = (x, y) => {
    sessionStorage.setItem('iam:tilt:handoff', JSON.stringify({ x, y, t: Date.now() }));
  };
  target.addEventListener('click', (e) => {
    const r = target.getBoundingClientRect();
    const px = (e.clientX - r.left) / r.width - 0.5;
    const py = (e.clientY - r.top) / r.height - 0.5;
    writeHandoff(py * -3, px * 3);
    requestAnimationFrame(() => { window.location.href = '/demo'; });
  });
  target.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    e.preventDefault();
    writeHandoff(0, 0);
    requestAnimationFrame(() => { window.location.href = '/demo'; });
  });
}
</script>
