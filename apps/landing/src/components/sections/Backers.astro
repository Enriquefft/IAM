---
// Backers.astro — social proof strip with two backer logos.
// section-backers.jsx:3-41.
import Label from "@/components/typography/Label.astro";
---

{/* section-backers.jsx:4 — aria-label="Respaldados por" */}
<section
  aria-label="Respaldados por"
  class="bg-surface-alt border-y border-surface-border py-10"
>
  <div class="mx-auto max-w-page px-8">
    <div class="flex flex-wrap items-center justify-center gap-x-14 gap-y-6">
      {/* section-backers.jsx:17 */}
      <Label class="uppercase tracking-wide text-text-muted">
        Respaldados por
      </Label>

      {/* section-backers.jsx:20-27 — Utec Ventures */}
      <a
        href="https://www.utecventures.com"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Utec Ventures"
        class="inline-flex items-center saturate-90 transition-[filter,transform] duration-medium ease-out hover:saturate-100 hover:-translate-y-px motion-reduce:hover:transform-none motion-reduce:transition-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-alt rounded-base"
      >
        {/* section-backers.jsx:24-26 */}
        <img
          src="/backers/utec-ventures.png"
          alt="Utec Ventures"
          class="h-8 w-auto object-contain"
          width="128"
          height="32"
          loading="lazy"
          decoding="async"
        />
      </a>

      {/* section-backers.jsx:30-37 — 404 Tech Found */}
      <a
        href="https://www.404techfound.com"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="404 Tech Found"
        class="inline-flex items-center saturate-90 transition-[filter,transform] duration-medium ease-out hover:saturate-100 hover:-translate-y-px motion-reduce:hover:transform-none motion-reduce:transition-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-alt rounded-base"
      >
        {/* section-backers.jsx:34-36 */}
        <img
          src="/backers/404-tech-found.svg"
          alt="404 Tech Found"
          class="h-14 w-auto object-contain"
          width="112"
          height="56"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>
  </div>
</section>
