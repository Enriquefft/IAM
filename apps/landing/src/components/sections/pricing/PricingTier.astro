---
// PricingTier.astro — single pricing tier card.
// section-pricing.jsx:70-127.
import Small from "@/components/typography/Small.astro";
import Icon from "@/components/icons/Icon.astro";

interface Props {
  readonly id: string;
  readonly name: string;
  readonly priceText: string;
  readonly periodLabel: string;
  readonly desc: string;
  readonly features: readonly string[];
  readonly cta: { readonly label: string; readonly href: string };
  readonly highlighted?: boolean;
}

const {
  id,
  name,
  priceText,
  periodLabel,
  desc,
  features,
  cta,
  highlighted = false,
}: Props = Astro.props;
---

{/* section-pricing.jsx:76-88 — card article */}
<article
  aria-labelledby={`tier-${id}`}
  data-highlighted={highlighted ? "true" : undefined}
  class="relative flex flex-col rounded-lg p-8 bg-surface border border-surface-border shadow-sm
    data-[highlighted=true]:shadow-md data-[highlighted=true]:border-2 data-[highlighted=true]:border-primary
    data-[highlighted=true]:-translate-y-1 motion-reduce:data-[highlighted=true]:translate-y-0"
>
  {/* section-pricing.jsx:87-93 — "El más elegido" ribbon */}
  {highlighted && (
    <span
      class="absolute -top-3 left-1/2 -translate-x-1/2 inline-flex items-center rounded-full bg-primary-hover text-text-inverse px-3 py-1 text-micro font-semibold uppercase tracking-wide"
    >
      {/* section-pricing.jsx:93 */}
      El más elegido
    </span>
  )}

  {/* section-pricing.jsx:95-103 — tier header */}
  <div class="mb-6">
    {/* section-pricing.jsx:96 */}
    <h3 id={`tier-${id}`} class="font-sans text-h3 text-text-primary mb-1">{name}</h3>
    <div class="flex items-baseline gap-1.5 mt-3">
      {/* section-pricing.jsx:99-101 — price display, text-[40px] no exact token */}
      <span class="font-sans text-[40px] font-bold tracking-tight text-text-primary leading-none"> {/* section-pricing.jsx:99 */}
        {priceText}
      </span>
      <Small class="text-text-muted">{periodLabel}</Small>
    </div>
    <p class="font-sans text-small text-text-secondary mt-2">{desc}</p>
  </div>

  {/* section-pricing.jsx:105-116 — feature list */}
  <ul role="list" class="flex flex-col gap-3 mb-8 flex-1" style="list-style:none;padding:0;margin:0;">
    {features.map((feat) => (
      <li class="flex gap-2.5 items-start">
        {/* section-pricing.jsx:112 — check icon chip */}
        <span class="inline-grid h-4.5 w-4.5 place-items-center rounded-sm bg-status-successSurface text-primary-active shrink-0 mt-0.5">
          <Icon name="check" size={12} />
        </span>
        <Small class="text-text-secondary">{feat}</Small>
      </li>
    ))}
  </ul>

  {/* section-pricing.jsx:118-127 — CTA */}
  <a
    href={cta.href}
    class={`w-full inline-flex items-center justify-center rounded-base h-11 px-6 text-small font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-page ${
      highlighted
        ? "bg-primary text-primary-fg hover:bg-primary-hover active:bg-primary-active"
        : "border border-surface-border bg-surface text-text-primary hover:bg-surface-alt"
    }`}
  >
    {cta.label}
  </a>
</article>
