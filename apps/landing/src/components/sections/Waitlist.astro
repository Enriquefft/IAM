---
import WaitlistForm from "./waitlist/WaitlistForm";
import { WAITLIST_COPY } from "./waitlist/copy";
---

<section
  id="waitlist"
  aria-labelledby="waitlist-title"
  class="bg-surface-alt py-24 tablet:py-16"
>
  <div class="mx-auto max-w-section px-8">
    <div class="mx-auto max-w-[520px]">
      <span class="inline-flex items-center rounded-full bg-brand-salvia-100 text-brand-salvia-600 text-label font-medium px-3 py-1 mb-5">
        {WAITLIST_COPY.eyebrow}
      </span>

      <h2
        id="waitlist-title"
        class="text-h2 font-bold text-text-primary mb-4"
      >
        {WAITLIST_COPY.heading}
      </h2>

      <p class="text-body-lg text-text-secondary font-serif mb-8">
        {WAITLIST_COPY.lede}
      </p>

      <WaitlistForm action="/api/waitlist/signup" client:load />
    </div>
  </div>
</section>
