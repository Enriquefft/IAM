---
// AgendaPreview.astro — schematic calendar preview for Agenda feature card.
// section-features.jsx:130-164. Static, zero JS.
---

<div class="absolute inset-0 p-3.5 flex flex-col gap-1.5">
  {/* section-features.jsx:132 — header row */}
  <div class="flex justify-between items-center mb-1">
    <span class="font-sans text-[11px] font-semibold text-text-primary">
      {/* section-features.jsx:133 */}
      Mayo
    </span>
    <div class="flex gap-1">
      {/* section-features.jsx:135 */}
      {["L", "M", "M", "J", "V"].map((d) => (
        <span class="w-4.5 h-4.5 text-[9px] text-text-muted grid place-items-center font-sans">
          {d}
        </span>
      ))}
    </div>
  </div>

  {/* section-features.jsx:140-162 — session rows */}
  <div class="flex items-center gap-2 px-2 py-1.5 rounded-sm bg-transparent border border-transparent">
    <span class="font-sans text-[10px] font-semibold text-text-primary w-8">9:00</span>
    <span class="font-sans text-[10px] text-text-secondary flex-1">Carlos D.</span>
    <span class="w-3 h-3 rounded-full bg-status-successSurface text-primary-active grid place-items-center">
      <svg width="6" height="6" viewBox="0 0 6 6" fill="none" aria-hidden="true">
        <path d="M1 3l1.5 1.5L5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>

  <div class="flex items-center gap-2 px-2 py-1.5 rounded-sm bg-surface border border-brand-salvia-200">
    <span class="font-sans text-[10px] font-semibold text-text-primary w-8">11:00</span>
    <span class="font-sans text-[10px] text-text-secondary flex-1">Ana M.</span>
    <span class="w-3 h-3 rounded-full bg-status-successSurface text-primary-active grid place-items-center">
      <svg width="6" height="6" viewBox="0 0 6 6" fill="none" aria-hidden="true">
        <path d="M1 3l1.5 1.5L5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>

  <div class="flex items-center gap-2 px-2 py-1.5 rounded-sm bg-transparent border border-transparent">
    <span class="font-sans text-[10px] font-semibold text-text-primary w-8">13:30</span>
    <span class="font-sans text-[10px] text-text-secondary flex-1">Lucía P.</span>
    {/* section-features.jsx:159 — "pendiente" label */}
    <span class="font-sans text-[9px] text-status-error">pendiente</span>
  </div>

  <div class="flex items-center gap-2 px-2 py-1.5 rounded-sm bg-transparent border border-transparent">
    <span class="font-sans text-[10px] font-semibold text-text-primary w-8">17:00</span>
    <span class="font-sans text-[10px] text-text-secondary flex-1">Diego H.</span>
    <span class="w-3 h-3 rounded-full bg-status-successSurface text-primary-active grid place-items-center">
      <svg width="6" height="6" viewBox="0 0 6 6" fill="none" aria-hidden="true">
        <path d="M1 3l1.5 1.5L5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>
</div>
