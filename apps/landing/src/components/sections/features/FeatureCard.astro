---
// FeatureCard.astro — single feature card with preview area, title, body, bullet list.
// section-features.jsx:89-127.
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import Body from "@/components/typography/Body.astro";
import Small from "@/components/typography/Small.astro";
import Icon from "@/components/icons/Icon.astro";

interface Props {
  readonly title: string;
  readonly body: string;
  readonly bullets: readonly string[];
  readonly PreviewComponent: AstroComponentFactory;
}

const { title, body, bullets, PreviewComponent }: Props = Astro.props;
---

{/* section-features.jsx:90-97 */}
<article class="flex flex-col gap-4.5 rounded-lg border border-surface-border bg-surface p-6 shadow-sm">
  {/* section-features.jsx:98-105 — preview frame */}
  <div
    class="relative aspect-[5/3] overflow-hidden rounded-base bg-surface-alt border border-surface-border"
    aria-hidden="true"
  >
    <PreviewComponent />
  </div>

  <div>
    {/* section-features.jsx:109 */}
    <h3 class="font-sans text-h3 text-text-primary mb-2.5">{title}</h3>
    {/* section-features.jsx:110 */}
    <Body class="text-text-secondary">{body}</Body>
  </div>

  {/* section-features.jsx:112-125 — bullet list */}
  <ul role="list" class="flex flex-col gap-2 mt-auto" style="list-style:none;padding:0;margin:0;">
    {bullets.map((bullet) => (
      <li class="flex gap-2.5 items-center">
        {/* section-features.jsx:116-119 — check icon chip */}
        <span class="inline-grid h-4.5 w-4.5 place-items-center rounded-sm bg-status-successSurface text-primary-active shrink-0">
          <Icon name="check" size={12} />
        </span>
        <Small class="text-text-secondary">{bullet}</Small>
      </li>
    ))}
  </ul>
</article>
